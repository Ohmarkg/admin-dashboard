# Emulator-only dev environment — committed on purpose; contains NO secrets.
# (Real credentials are wired only at cutover — BUILD_PLAN Phase 6.)
# docker-compose overrides the emulator hosts for the containerized setup.
NEXT_PUBLIC_GOOGLE_API_KEY=dummy-emulator-key
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=true
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199
